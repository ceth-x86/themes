{
  "name": "Stradarium Modern",
  "type": "light",
  "colors": {
    "editor.background": "#FFFCF0",
    "editor.foreground": "#100F0F",
    "editorLineNumber.foreground": "#B7B5AC",
    "editorLineNumber.activeForeground": "#6D6C67",
    "editorCursor.foreground": "#100F0F",
    "editor.selectionBackground": "#DDE5F3",
    "editor.selectionHighlightBackground": "#E8E2D6",
    "editor.wordHighlightBackground": "#E8E2D6",
    "editor.wordHighlightStrongBackground": "#DDE5F3",
    "editor.findMatchBackground": "#8D640033",
    "editor.findMatchBorder": "#8D6400",
    "editor.findMatchHighlightBackground": "#8D640022",
    "editorHoverWidget.background": "#F6F2E8",
    "editorHoverWidget.border": "#CFC9B9",
    "editorWidget.background": "#F6F2E8",
    "editorWidget.border": "#CFC9B9",
    "editorIndentGuide.background1": "#E6E0D0",
    "editorIndentGuide.activeBackground1": "#B7B5AC",
    "editorBracketMatch.background": "#1978701A",
    "editorBracketMatch.border": "#197870",

    // < --
    "editorGroupHeader.tabsBackground": "#F6F2E8",
    "editorGroupHeader.noTabsBackground": "#F6F2E8",
    "editorGroupHeader.border": "#E6E0D0",
    "tab.unfocusedActiveBackground": "#E8E2D6",
    "tab.unfocusedActiveForeground": "#403E3C",
    "tab.unfocusedInactiveBackground": "#FBF7EF",
    "tab.unfocusedInactiveForeground": "#6D6C67",
    "editorPane.background": "#FFFCF0",
    // -- >

    // <--
    "terminal.background": "#FFFCF0",
    "terminal.foreground": "#100F0F",
    "terminal.ansiBlack": "#100F0F",
    "terminal.ansiRed": "#C13D31",
    "terminal.ansiGreen": "#5B7500",
    "terminal.ansiYellow": "#8D6400",
    "terminal.ansiBlue": "#205EA6",
    "terminal.ansiMagenta": "#A02F6F",
    "terminal.ansiCyan": "#197870",
    "terminal.ansiWhite": "#CFC9B9",
    "terminal.ansiBrightBlack": "#6D6C67",
    "terminal.ansiBrightRed": "#E76B5D",
    "terminal.ansiBrightGreen": "#7A9A12",
    "terminal.ansiBrightYellow": "#BE9207",
    "terminal.ansiBrightBlue": "#4385BE",
    "terminal.ansiBrightMagenta": "#CE5D97",
    "terminal.ansiBrightCyan": "#3AA99F",
    "terminal.ansiBrightWhite": "#FFFCF0",
    // -->


    "sideBar.background": "#F8F4EA",
    "sideBar.foreground": "#403E3C",
    "sideBar.border": "#CFC9B9",

    "activityBar.background": "#F2EDE3",
    "activityBar.foreground": "#100F0F",
    "activityBar.inactiveForeground": "#6D6C67",
    "activityBar.border": "#CFC9B9",

    "titleBar.activeBackground": "#F8F4EA",
    "titleBar.activeForeground": "#100F0F",
    "titleBar.inactiveBackground": "#F8F4EA",
    "titleBar.inactiveForeground": "#6D6C67",
    "titleBar.border": "#CFC9B9",

    "statusBar.background": "#F2EDE3",
    "statusBar.foreground": "#403E3C",
    "statusBar.border": "#CFC9B9",
    "statusBar.debuggingBackground": "#A02F6F",
    "statusBar.debuggingForeground": "#FFFCF0",

    "tab.activeBackground": "#E8E2D6",
    "tab.activeForeground": "#100F0F",
    "tab.inactiveBackground": "#FBF7EF",
    "tab.inactiveForeground": "#6D6C67",
    "tab.border": "#E6E0D0",
    "tab.hoverBackground": "#F8F4EA",
    "tab.unfocusedHoverBackground": "#F8F4EA",
    "tab.activeBorderTop": "#F8F4EA",

    "input.background": "#F8F4EA",
    "input.foreground": "#100F0F",
    "input.border": "#CFC9B9",
    "input.placeholderForeground": "#6D6C67",

    "list.hoverBackground": "#F2EDE3",
    "list.activeSelectionBackground": "#E8E2D6",
    "list.activeSelectionForeground": "#100F0F",
    "list.inactiveSelectionBackground": "#F2EDE3",

    "panel.background": "#FFFCF0",
    "panel.border": "#CFC9B9"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6D6C67",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#A02F6F"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#205EA6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#197870"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#5B7500"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#8D6400"
      }
    },
    {
      "scope": [
        "variable",
        "identifier"
      ],
      "settings": {
        "foreground": "#100F0F"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6D6C67"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#197870"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#6D6C67"
      }
    }
  ]
}
